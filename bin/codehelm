#!/usr/bin/env node
/* eslint-disable no-console */
import { spawn } from 'node:child_process';
import { mkdir, rm, chmod } from 'node:fs/promises';
import { createServer } from 'node:net';
import { randomBytes, randomUUID } from 'node:crypto';
import { accessSync, constants as fsConstants, existsSync, realpathSync } from 'node:fs';
import { tmpdir } from 'node:os';
import { dirname, join, resolve } from 'node:path';
import { fileURLToPath } from 'node:url';
import { request } from 'node:http';

const __dirname = dirname(fileURLToPath(import.meta.url));
const ROOT = resolve(__dirname, '..');

const MIN_PORT = 49152;
const MAX_PORT = 65535;

async function findPort() {
  for (let i = 0; i < 30; i++) {
    const candidate = MIN_PORT + Math.floor(Math.random() * (MAX_PORT - MIN_PORT));
    const ok = await tryBind(candidate);
    if (ok) return candidate;
  }
  return osAssignedPort();
}

function tryBind(port) {
  return new Promise((resolve) => {
    const s = createServer();
    s.once('error', () => resolve(false));
    s.listen({ port, host: '127.0.0.1' }, () => {
      s.close(() => resolve(true));
    });
  });
}

function osAssignedPort() {
  return new Promise((resolve, reject) => {
    const s = createServer();
    s.once('error', reject);
    s.listen({ port: 0, host: '127.0.0.1' }, () => {
      const addr = s.address();
      if (addr && typeof addr === 'object') {
        const port = addr.port;
        s.close(() => resolve(port));
      } else {
        s.close(() => reject(new Error('cannot obtain port')));
      }
    });
  });
}

function runtimeRootDir() {
  const candidates = [process.env['XDG_RUNTIME_DIR'], process.env['TMPDIR'], tmpdir()].filter(
    (v) => typeof v === 'string' && v.length > 0,
  );
  for (const dir of candidates) {
    if (existsSync(dir)) return dir;
  }
  return tmpdir();
}

async function pickProfileDir() {
  const base = runtimeRootDir();
  const uid = process.getuid ? process.getuid() : 'anon';
  const dir = join(base, `codehelm-${uid}-${randomUUID()}`);
  await mkdir(dir, { recursive: true, mode: 0o700 });
  await chmod(dir, 0o700);
  return dir;
}

function chromiumCandidates() {
  const override = process.env['CODEHELM_CHROMIUM'];
  const base = override && override.length > 0 ? [override] : [];
  if (process.platform === 'darwin') {
    return [
      ...base,
      '/Applications/Google Chrome.app/Contents/MacOS/Google Chrome',
      '/Applications/Chromium.app/Contents/MacOS/Chromium',
      '/Applications/Arc.app/Contents/MacOS/Arc',
      '/Applications/Brave Browser.app/Contents/MacOS/Brave Browser',
      '/Applications/Microsoft Edge.app/Contents/MacOS/Microsoft Edge',
    ];
  }
  return [
    ...base,
    '/usr/bin/chromium',
    '/usr/bin/chromium-browser',
    '/usr/bin/google-chrome-stable',
    '/usr/bin/google-chrome',
    '/snap/bin/chromium',
  ];
}

function findChromium() {
  for (const candidate of chromiumCandidates()) {
    if (!candidate) continue;
    try {
      const resolved = realpathSync(candidate);
      accessSync(resolved, fsConstants.X_OK);
      return resolved;
    } catch {
      // try next
    }
  }
  throw new Error(
    'Chromium/Chrome not found. Install chromium or set CODEHELM_CHROMIUM=/path/to/chrome.',
  );
}

function waitForHealth(port, attempts = 100, intervalMs = 100) {
  return new Promise((resolveFn, rejectFn) => {
    let left = attempts;
    const retry = () => {
      if (--left <= 0) rejectFn(new Error('health check timed out'));
      else setTimeout(tick, intervalMs);
    };
    const tick = () => {
      const req = request(
        { host: '127.0.0.1', port, path: '/api/healthz', method: 'GET' },
        (res) => {
          if (res.statusCode === 200) {
            res.resume();
            resolveFn();
          } else {
            res.resume();
            retry();
          }
        },
      );
      req.once('error', retry);
      req.setTimeout(500, () => req.destroy());
      req.end();
    };
    tick();
  });
}

const CLI_FLAGS = process.argv.slice(2);
const FORCE_DEV = CLI_FLAGS.includes('--dev');
const FORCE_BUILD = CLI_FLAGS.includes('--build');
const WANT_HELP = CLI_FLAGS.includes('--help') || CLI_FLAGS.includes('-h');

function printHelp() {
  console.log(`codehelm — local Claude Code session manager

Usage:
  codehelm [--dev] [--build] [--help]

Flags:
  --dev      Run Next.js in development mode (HMR, slower cold start).
             Default is production when a build is present under .next/.
  --build    Run \`pnpm build\` before starting (picks up source changes).
  --help     Show this message.

Environment:
  CODEHELM_CHROMIUM   Override Chromium/Chrome path auto-detection.
  LOG_LEVEL           pino log level (default: info).`);
}

function runBuildStep() {
  return new Promise((res, rej) => {
    const p = spawn('pnpm', ['build'], { cwd: ROOT, stdio: 'inherit' });
    p.on('exit', (code) => {
      if (code === 0) res();
      else rej(new Error(`pnpm build failed (exit ${code ?? 'null'})`));
    });
  });
}

function prewarmEndpoints(port, token) {
  // Fire-and-forget fetches to trigger lazy module loads on the server
  // (JSONL parser, watcher subscribers, settings IO). Ignored on failure.
  const paths = ['/api/projects', '/api/settings'];
  for (const path of paths) {
    const req = request(
      {
        host: '127.0.0.1',
        port,
        path,
        method: 'GET',
        headers: { cookie: `codehelm_auth=${token}` },
      },
      (res) => res.resume(),
    );
    req.once('error', () => {});
    req.setTimeout(2000, () => req.destroy());
    req.end();
  }
}

async function main() {
  if (WANT_HELP) {
    printHelp();
    process.exit(0);
  }

  // Build mode decision. Priority: --dev wins, then --build forces a rebuild,
  // otherwise we use prod when .next/BUILD_ID exists and fall back to dev with
  // a warning if it doesn't.
  const buildIdPath = resolve(ROOT, '.next/BUILD_ID');
  if (FORCE_BUILD && !FORCE_DEV) {
    console.error('codehelm: rebuilding (--build)…');
    await runBuildStep();
  }
  const hasBuild = existsSync(buildIdPath);
  const useProd = !FORCE_DEV && hasBuild;
  if (!useProd && !FORCE_DEV) {
    console.error(
      'codehelm: no production build found (.next/BUILD_ID missing). Falling back to dev mode.',
    );
    console.error('         Run `pnpm build` (or `bin/codehelm --build`) once for ~5-10× faster starts.');
  } else if (useProd) {
    console.error('codehelm: using production build.');
  } else {
    console.error('codehelm: dev mode forced (--dev).');
  }

  const port = await findPort();
  const token = randomBytes(32).toString('hex');

  const env = {
    ...process.env,
    PORT: String(port),
    CODEHELM_TOKEN: token,
    HOST: '127.0.0.1',
    NODE_ENV: useProd ? 'production' : 'development',
  };

  // Our custom server.ts always runs through tsx — in prod, Next detects
  // NODE_ENV and serves the pre-built .next/ tree (no on-demand compile,
  // React in prod mode, minified bundle). The tsx wrap costs ~150 ms at
  // startup, trivial vs the savings.
  const cmd = 'pnpm';
  const args = ['exec', 'tsx', 'server.ts'];

  const server = spawn(cmd, args, {
    cwd: ROOT,
    env,
    stdio: ['ignore', 'inherit', 'inherit'],
  });

  const profileDir = await pickProfileDir();
  let chromeProc = null;
  let exiting = false;

  const cleanup = async (signal, code = 0) => {
    if (exiting) return;
    exiting = true;
    try {
      if (chromeProc && !chromeProc.killed) chromeProc.kill('SIGTERM');
    } catch {}
    try {
      if (server && !server.killed) server.kill('SIGTERM');
    } catch {}
    try {
      if (existsSync(profileDir)) await rm(profileDir, { recursive: true, force: true });
    } catch (err) {
      console.error('cleanup error:', err.message);
    }
    process.exit(code);
  };

  process.on('SIGTERM', () => cleanup('SIGTERM'));
  process.on('SIGINT', () => cleanup('SIGINT'));
  process.on('SIGHUP', () => cleanup('SIGHUP'));

  server.on('exit', (code) => {
    if (!exiting) console.error(`server exited with code ${code ?? 'null'}`);
    cleanup('server-exit', code ?? 1);
  });

  try {
    await waitForHealth(port);
  } catch (err) {
    console.error('server did not become healthy:', err.message);
    await cleanup('health-fail', 1);
    return;
  }

  // Prewarm lazy server-side modules while Chromium starts.
  prewarmEndpoints(port, token);

  const chromium = findChromium();
  const url = `http://127.0.0.1:${port}/api/auth?k=${token}`;
  chromeProc = spawn(
    chromium,
    [
      `--app=${url}`,
      `--user-data-dir=${profileDir}`,
      '--no-first-run',
      '--no-default-browser-check',
      // Perf flags: strip the things a local dev tool will never use.
      '--disable-extensions',
      '--disable-background-networking',
      '--disable-sync',
      '--disable-default-apps',
      '--no-pings',
      '--metrics-recording-only',
      '--disable-features=TranslateUI,OptimizationHints,InterestFeedContentSuggestions',
      // Persist static-asset cache across launches under our profile dir.
      '--disk-cache-size=104857600',
    ],
    { stdio: 'ignore', detached: false },
  );

  chromeProc.on('exit', () => {
    cleanup('chrome-exit', 0);
  });

  console.error(`codehelm ready → http://127.0.0.1:${port}`);
}

main().catch((err) => {
  console.error('codehelm fatal:', err.message);
  process.exit(1);
});
